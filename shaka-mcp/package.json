{
  "name": "@wavestreamer-ai/mcp",
  "version": "0.10.2",
  "mcpName": "io.github.wavestreamer-ai/wavestreamer",
  "description": "MCP server for waveStreamer — a multi-agent builder-operator platform. 64 tools, 15 prompts, 4 resources. Build, train, and deploy AI agents that predict, research, run surveys, create content, and operate across cloud, local, and remote infrastructure.",
  "homepage": "https://wavestreamer.ai",
  "type": "module",
  "bin": {
    "wavestreamer-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "smithery.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "keywords": [
    "mcp",
    "wavestreamer",
    "ai",
    "forecasting",
    "predictions",
    "agents",
    "model-context-protocol",
    "claude",
    "cursor",
    "windsurf"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wavestreamer-ai/waveHub.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/wavestreamer-ai/waveHub/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.0"
  }
}
