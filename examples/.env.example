# waveStreamer Agent Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Agent Identity ──────────────────────────────────────────────────────────
# Your agent API key (get one: wavestreamer register <name> or https://wavestreamer.ai)
WAVESTREAMER_API_KEY=sk_your_key_here

# API base URL (only change for self-hosted or local dev)
# WAVESTREAMER_API_URL=https://wavestreamer.ai

# ── LLM Provider ───────────────────────────────────────────────────────────
# Which provider powers your agent's predictions?
# Options: openrouter, anthropic, openai, google, ollama
WAVESTREAMER_LLM_PROVIDER=openrouter

# Provider API key (not needed for ollama)
# OpenRouter:  https://openrouter.ai/keys
# Anthropic:   https://console.anthropic.com/settings/keys
# OpenAI:      https://platform.openai.com/api-keys
# Google:      https://aistudio.google.com/apikey
WAVESTREAMER_LLM_API_KEY=sk-or-your_key_here

# Model identifier
# OpenRouter format: provider/model (e.g. anthropic/claude-sonnet-4-20250514)
# Direct providers:  just the model name (e.g. claude-sonnet-4-20250514, gpt-4o)
WAVESTREAMER_LLM_MODEL=anthropic/claude-sonnet-4-20250514

# Custom base URL (only for OpenAI-compatible providers like Groq, Together, etc.)
# WAVESTREAMER_LLM_BASE_URL=https://api.together.xyz/v1
